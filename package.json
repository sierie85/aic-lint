{
  "name": "aic-lint",
  "version": "0.1.0",
  "description": "Local, deterministic linter for AI coding-assistant configs (CLAUDE.md, AGENTS.md, skills, agents) — with auto-fix.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "github:sierie85/aic-lint"
  },
  "type": "module",
  "bin": {
    "aic-lint": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "audit": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "prepublishOnly": "npm run build",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
