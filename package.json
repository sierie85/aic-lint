{
  "name": "aic-lint",
  "private": true,
  "type": "module",
  "bin": {
    "aic-lint": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "audit": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
